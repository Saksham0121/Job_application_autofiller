{
  "manifest_version": 3,
  "name": "Job Autofiller — AI Job Application Assistant",
  "version": "1.0.0",
  "description": "Automatically detect and fill job application forms using your saved profile. Powered by Gemini AI.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Job Autofiller"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.greenhouse.io/*",
        "*://*.lever.co/*",
        "*://*.ashbyhq.com/*",
        "*://*.myworkdayjobs.com/*",
        "*://*.workday.com/*",
        "*://*.smartrecruiters.com/*",
        "*://*.taleo.net/*",
        "*://*.icims.com/*",
        "*://*.jobvite.com/*",
        "*://*.recruitee.com/*",
        "*://*.bamboohr.com/*",
        "*://*.linkedin.com/jobs/*",
        "*://*.indeed.com/apply/*",
        "*://jobs.*/*",
        "*://careers.*/*"
      ],
      "js": ["content/detector.js", "content/autofill.js", "content/review-panel.js"],
      "css": ["content/panel.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://api.jobautofiller.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "content/panel.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
